#compdef _amir amir

_amir() {
    local cur prev context state line
    cur="${words[CURRENT]}"
    prev="${words[CURRENT-1]}"

    # Step 1: Main commands
    if (( CURRENT == 2 )); then
        local -a commands
        commands=(
            'init-project:Scaffold Agent Constitution in directory'
            'sync-constitution:Sync .agent/ rules+skills from agent-constitution repo'
            'update-projects:Update constitution + install pre-commit hook across all projects'
            'video:Advanced video processing (compress, cut, batch)'
            'audio:Audio tools (convert, extract, concat, to-video)'
            'img:Resize images (logo and custom sizes)'
            'pdf:Convert images to PDF with custom sizing'
            'info:Show file technical properties'
            'transfer:Upload temporary file and get link'
            'lock:Encrypt and lock file'
            'unlock:Unlock encrypted file'
            'clean:Clean system caches and trash'
            'qr:Create smart QR Code'
            'weather:Show weather information'
            'keyboard:Show keyboard layout (FR/EN/FA) with key combos'
            'kb:Alias for keyboard'
            'short:Shorten long URLs'
            'pass:Generate secure password'
            'speed:Test internet speed'
            'todo:Manage quick task list'
            'clip:Copy text or file to clipboard'
            'chat:Ask Gemini/Gemma anything'
            'code:Generate code and save to file'
            'apply:Tailor CV and Cover Letter for a job from a URL'
            'watermark:Add logo or text watermark to images/videos'
            'subtitle:Generate multi-language subtitles using AI'
            'llm-lists:Fetch model lists from LLM providers'
            'download:Download video, photo or carousel from YouTube, Instagram, TikTok, Twitter/X and 1000+ sites'
            'dl:Alias for download'
            'trend:Trending content and research — YouTube, GitHub, arXiv, Reddit...'
            'research:Alias for trend'
        )
        _describe -t commands 'amir commands' commands
        return
    fi

    # Step 2: Subcommand options
    case "${words[2]}" in

        sync-constitution)
            _arguments '*:target directory:_directories'
            ;;

        update-projects)
            _arguments \
                '1::base directory:_directories' \
                '--dry-run[List what would happen, change nothing]' \
                '--no-hook[Do not install the pre-commit hook]' \
                '--no-submodule[Do not update the constitution submodule]' \
                '--exclude[Project names to skip]:names'
            ;;

        trend)
            _trend_arguments
            ;;

        research)
            case "${words[3]}" in
                discover)
                    _arguments -s \
                        '--keywords[Topic keywords]+: :' \
                        '--sources[Sources to search]:source:(arxiv dblp)' \
                        '--since-year[Papers since year]:year:(2020 2021 2022 2023 2024)' \
                        '--min-papers[Min papers per author]:count:(1 2 3 5)' \
                        '--top[Candidates to show]:count:(5 10 15 20)' \
                        '--format[Output format]:format:(txt md xlsx)' \
                        '--categories[ArXiv category filter]+: :' \
                        '--profile[Candidate profile .md]:file:_files' \
                        '--save[Override output path]:file:_files' \
                        {-h,--help}'[Show help]'
                    ;;
                professor)
                    _arguments -s \
                        '--professor[Professor full name]: :' \
                        '--institution[Institution / lab]: :' \
                        '--email[Professor email]: :' \
                        '--gender[Gender for salutation]:gender:(M F)' \
                        '--lang[Email language]:lang:(fr en)' \
                        '--story[Candidate motivation]: :' \
                        '--since-year[Papers since year]:year:(2020 2021 2022 2023)' \
                        '--scholar-url[Google Scholar or personal page URL]: :' \
                        '--profile[Candidate profile .md]:file:_files' \
                        '--tracking[Path to tracking.json]:file:_files' \
                        '--position-id[Position ID in tracking.json]: :' \
                        {-h,--help}'[Show help]'
                    ;;
                *)
                    _values 'research subcommand' \
                        'discover[Find supervisors by topic keywords (ArXiv + DBLP)]' \
                        'professor[Research a specific professor: papers → overlap → email]'
                    ;;
            esac
            ;;

        pdf)
            case $((CURRENT)) in
                *)
                    # PDF command: Uses standard argument parsing
                    _arguments -s \
                        '--smart[Smart Crop (content-aware trimming)]' \
                        '--engine[Specify rendering engine]:engine:(puppeteer weasyprint pil pandoc)' \
                        '--weasyprint[Use WeasyPrint engine]' \
                        '--pil[Use PIL grayscale fallback engine]' \
                        '--pandoc[Use Pandoc engine]' \
                        '(-f --free-size)'{-f,--free-size}'[Generate a single continuous PDF with custom dimensions]' \
                        '--page-width[Set PDF width in pixels for free-size/custom layout]:width (px):(1200 1440 1600 1800 2000 2480 max-content fit-content nowrap)' \
                        '--page-height[Set PDF height in pixels for free-size/custom layout]:height (px):(1600 2000 2480 3000 3508 4000)' \
                        {-o,--output}'[Specify output file]:filename:_files' \
                        {-r,--rotate}'[Rotate images (degrees)]:angle' \
                        {-q,--quality}'[JPEG Quality (default: 60)]:quality (0-100)' \
                        '--resize[Resize percentage (default: 50)]:percentage' \
                        '--pages[Create multi-page PDF (1 image per page) instead of collage]' \
                        '--merge[Merge multiple files into a single PDF (alias for --pages)]' \
                        '--radius[Corner radius (px)]:pixels' \
                        '--no-round[Disable corner rounding]' \
                        '--square[Alias for --no-round]' \
                        '--no-deskew[Disable auto-straightening]' \
                        '--no-straighten[Alias for --no-deskew]' \
                        '*:images:_files -g "*.(jpg|jpeg|png|webp|pdf|md|txt|JPG|PNG|WEBP|PDF|MD|TXT)"'
                    ;;
            esac
            ;;

        watermark)
            if (( CURRENT >= 3 )); then
                _arguments \
                    '-o[Output file path]:output file:_files' \
                    '-i[Watermark image path]:watermark image:_files' \
                    '-t[Watermark text]:text' \
                    '-p[Position]:position:(SE SW NE NW C)' \
                    '*:input file:_files'
            fi
            ;;

        video)
            local -a video_subcmds
            video_subcmds=(
                'subtitle:Transcribe + translate video (Whisper AI + LLM). Also accepts a URL'
                'compress:Process video with smart selection'
                'record:Record screen to video file via AVFoundation (macOS)'
                'pip:Picture-in-picture — overlay one or more videos onto a main video'
                'convert:Convert video format (mov→mp4, mkv, webm, avi…)'
                'cut:Cut / Trim video segment'
                'concat:Concatenate videos in the given order'
                'merge:Alias for concat'
                'split:Split video into ~N MB chunks'
                'batch:Batch process all videos in directory'
                'stats:Show AI learning statistics'
                'reset:Reset AI learning data'
                'codecs:Check encoder support'
            )

            if (( CURRENT == 3 )); then
                _describe -t commands 'video subcommand' video_subcmds
                return
            fi

            case "$words[3]" in
                record|rec)
                    case "$prev" in
                        --screen|--audio|--fps|--quality|-q)
                            _message 'number'
                            ;;
                        -o|--output)
                            _files
                            ;;
                        *)
                            _arguments -s \
                                '1: : ' '2: : ' \
                                '--list[List available screens and audio devices]' \
                                '--screen[Screen device index]:N: ' \
                                '--audio[Audio device index]:N: ' \
                                '--fps[Frame rate]:fps:(24 30 60)' \
                                '--no-audio[Record without audio]' \
                                '(-q --quality)'{-q,--quality}'[CRF quality (lower=better)]:N: ' \
                                '(-o --output)'{-o,--output}'[Output filename]:file:_files'
                            ;;
                    esac
                    ;;
                convert)
                    case "$prev" in
                        --to|-f)
                            _values 'format' mp4 mov mkv webm avi
                            ;;
                        -o|--output)
                            _files
                            ;;
                        *)
                            _arguments -s \
                                '1: : ' '2: : ' \
                                '3:video file:_files -g "*.mp4 *.mov *.mkv *.avi *.webm *.MP4 *.MOV *.MKV *.WEBM"' \
                                '(--to -f)'{--to,-f}'[Target format]:format:(mp4 mov mkv webm avi)' \
                                '(-o --output)'{-o,--output}'[Output filename]:output file:_files' \
                                '--reencode[Force re-encode instead of stream copy]'
                            ;;
                    esac
                    ;;
                batch)
                    _arguments -s \
                        '1: : ' '2: : ' \
                        '3:directory:_files -/' \
                        '4:resolution:_amir_resolutions' \
                        '5:quality:_amir_qualities' \
                        '--fps[Custom frame rate (e.g. 10 for 10fps)]:fps:(6 10 12 15 20 24 25 30)' \
                        '--split[Split output into chunks of N MB]:size in MB: ' \
                        '--gpu[Use hardware encoder (default on Apple Silicon)]' \
                        '--cpu[Use software encoder (better compression, recommended for text/screen recordings)]'
                    ;;
                cut|trim)
                    _arguments -s \
                        '1: : ' '2: : ' \
                        '3:video file:_files -g "*.mp4 *.mov *.mkv *.avi *.webm *.MP4 *.MOV *.MKV *.WEBM"' \
                        '(-s --start)'{-s,--start}'[Start time]:format HH\:MM\:SS or seconds (e.g. 00\:10\:30 or 630): ' \
                        '(-e --end -t --to)'{-e,--end,-t,--to}'[End time]:format HH\:MM\:SS or seconds (e.g. 01\:30\:00 or 5400): ' \
                        '--duration[Duration from start]:format HH\:MM\:SS or seconds (e.g. 00\:05\:00 or 300): ' \
                        '(-d --delete)'{-d,--delete}'[Delete range and stitch]:start time (then end time): ' \
                        '(-x --extract)'{-x,--extract}'[Extract only range into a clip]:start time (then end time): ' \
                        '(-o --output)'{-o,--output}'[Output filename]:output file:_files' \
                        '--split[Split output into chunks of N MB]:size in MB: ' \
                        '--subtitle-banner-image[Banner image behind subtitle area]:image file:_files -g "*.png *.jpg *.jpeg *.webp *.PNG *.JPG *.JPEG *.WEBP"' \
                        '--subtitle-banner-color[Fallback banner color when no banner image is provided]:color' \
                        '--subtitle-banner-height[Banner strip height percentage]:pct:(10 12 15 18 20 24 30)' \
                        '--subtitle-logo[Channel logo image on bottom-right]:logo file:_files -g "*.png *.jpg *.jpeg *.webp *.PNG *.JPG *.JPEG *.WEBP"' \
                        '--subtitle-logo-animated[Treat logo as animated overlay when possible]' \
                        '--subtitle-logo-width[Logo width percentage of video width]:pct:(6 8 10 12 15 18)' \
                        '--subtitle-logo-margin-right[Logo right margin in pixels]:px' \
                        '--subtitle-logo-margin-bottom[Logo bottom margin in pixels]:px' \
                        '*--guest-tag[Temporary guest label: START,DURATION,NAME,TITLE,POS (optional)]:guest tag' \
                        '--guest-tag-pos[Default position for guest tags]:pos:(br bl tr tl bc tc)' \
                        '--render[Re-encode video instead of copy stream]'
                    ;;
                split)
                    _arguments -s \
                        '1: : ' '2: : ' \
                        '3:video file:_files -g "*.mp4 *.mov *.mkv *.avi *.webm *.MP4 *.MOV *.MKV *.WEBM"' \
                        '4:chunk size in MB: '
                    ;;
                concat|merge)
                    case "$prev" in
                        -o|--output)
                            _files
                            ;;
                        *)
                            if [[ "$PREFIX" == -* ]]; then
                                local -a vm_opts
                                vm_opts=(
                                    '-o:Output video file'
                                    '--output:Output video file'
                                )
                                _describe -t vm_opts 'options' vm_opts
                            else
                                _files -g "*.mp4 *.mov *.mkv *.avi *.webm *.MP4 *.MOV *.MKV *.WEBM"
                            fi
                            ;;
                    esac
                    ;;
                compress)
                    _arguments -s \
                        '1: : ' '2: : ' \
                        '3:video file:_files -g "*.mp4 *.mov *.mkv *.avi *.webm *.MP4 *.MOV *.MKV *.WEBM"' \
                        '4:resolution:_amir_resolutions' \
                        '5:quality:_amir_qualities' \
                        '--fps[Custom frame rate (e.g. 10 for 10fps)]:fps:(6 10 12 15 20 24 25 30)' \
                        '--split[Split output into chunks of N MB]:size in MB: ' \
                        '--gpu[Use hardware encoder (default on Apple Silicon)]' \
                        '--cpu[Use software encoder (better compression, recommended for text/screen recordings)]'
                    ;;
                subtitle)
                    # amir video subtitle <file/url> — same flags as top-level amir subtitle
                    _arguments -s \
                        '1: : ' '2: : ' \
                        '3:video/SRT file or URL:_files -g "*.mp4 *.mov *.mkv *.avi *.MP4 *.MOV *.MKV *.webm *.WEBM *.srt *.SRT"' \
                        '(-s --source)'{-s,--source}'[Source language / audio language for Whisper (default\: auto)]:source lang:(auto en zh es hi ar bn pt ru ja fr de fa tr ko)' \
                        '*'{--sub,-t}'[Subtitle display langs in top→bottom order (repeatable)]:lang:(auto fa en de ar zh es fr ru ja ko tr pt hi)' \
                        '(-r --render)'{-r,--render}'[Burn subtitles into video (default\: enabled)]' \
                        '--ass-input[Render directly from a pre-edited ASS file (skip SRT→ASS conversion)]:ass file:_files -g "*.ass *.ASS"' \
                        '--sub-only[Generate subtitle files only — do not burn into video]' \
                        '--no-render[Alias for --sub-only (deprecated)]' \
                        '(-f --force)'{-f,--force}'[Force re-transcription]' \
                        '(-c --correct)'{-c,--correct}'[Correct transcription with AI]' \
                        '(-l --limit)'{-l,--limit}'[Time range — N seconds, or start end (use begin/start/end keywords)]:time:(begin end start)' \
                        '--llm[LLM bridge for translation]:llm:(deepseek gemini litellm minimax grok)' \
                        '--model[Specific LLM model code (for LiteLLM)]:model' \
                        '--native-lines[For mixed speech, keep or hide source lines already in target script]:mode:(keep hide on off)' \
                        '--whisper-model[Whisper model size/name]:model:((turbo\:Fastest\ reliable\ model large-v3\:Highest\ accuracy large-v2\:Legacy\ heavy\ model medium\:Balance\ of\ speed\ and\ accuracy small\:Fast\ but\ less\ accurate base\:Basic\ fallback tiny\:Ultra\ fast\ but\ inaccurate))' \
                        '--whisper-timing[Preserve Whisper timings and bypass internal timing normalization]' \
                        '--style[Subtitle style template]:style:(podcast lecture vlog short_form channel_brand_blue shorts_brand_blue news_guest_blue movie news custom)' \
                        '--resolution[Final burn resolution height]:height:(240 360 480 720 1080)' \
                        '--quality[Final burn quality 0-100]:quality:(40 50 60 70 80)' \
                        '--fps[Final burn FPS]:fps:(6 10 12 15 20 24 25 30)' \
                        '--split[Split final rendered output into N MB chunks]:size in MB: ' \
                        '--extreme[Fast defaults for subtitle pipeline\: 360p + q30]' \
                        '*--post[Generate posts after workflow (optional: telegram youtube linkedin)]:platform:(telegram youtube linkedin)' \
                        '*--post-only[Post only — skip processing (optional: telegram youtube linkedin)]:platform:(telegram youtube linkedin)' \
                        '--prompt-file[Custom prompt file for post generation]:file:_files' \
                        '--pad-bottom[Add black padding at bottom (percentage)]:pct' \
                        '--subtitle-banner-image[Banner image behind subtitle area]:image file:_files -g "*.png *.jpg *.jpeg *.webp *.PNG *.JPG *.JPEG *.WEBP"' \
                        '--subtitle-banner-color[Fallback banner color when no banner image is provided]:color' \
                        '--subtitle-banner-height[Banner strip height percentage]:pct:(10 12 15 18 20 24 30)' \
                        '--brand-kit[One-shot brand setup from logo path]:logo file:_files -g "*.png *.jpg *.jpeg *.webp *.svg *.SVG *.PNG *.JPG *.JPEG *.WEBP"' \
                        '--brand-kit-shorts[With --brand-kit use shorts sizing preset]' \
                        '--subtitle-logo[Channel logo image on bottom-right]:logo file:_files -g "*.png *.jpg *.jpeg *.webp *.PNG *.JPG *.JPEG *.WEBP"' \
                        '--subtitle-logo-animated[Treat logo as animated overlay when possible]' \
                        '--subtitle-logo-width[Logo width percentage of video width]:pct:(6 8 10 12 15 18)' \
                        '--subtitle-logo-margin-right[Logo right margin in pixels]:px' \
                        '--subtitle-logo-margin-bottom[Logo bottom margin in pixels]:px' \
                        '*--guest-tag[Temporary guest label: START,DURATION,NAME,TITLE,POS (optional)]:guest tag' \
                        '--guest-tag-pos[Default position for guest tags]:pos:(br bl tr tl bc tc)' \
                        '--raise-top[Move top subtitle upward by N pixels]:px' \
                        '--raise-bottom[Move bottom subtitle upward by N pixels]:px' \
                        '--shift[Shift subtitles in time (seconds): positive=later, negative=earlier]:seconds' \
                    '--no-vad[Disable Voice Activity Detection]' \
                        '--yt-subs[Use YouTube built-in subtitles instead of Whisper (manual first, auto-gen fallback)]' \
                        '--fps[Final burn FPS]:fps:(6 10 12 15 20 24 25 30)' \
                        '--split[Split final rendered output into N MB chunks]:size in MB: ' \
                        '--quality[Final burn quality 0-100]:quality:(40 50 60 70 80)' \
                        '--save[Save formats to export (srt ass all)]:format:(srt ass all)' \
                        '*--post-lang[Post language override]:lang:(fa en)' \
                        '--allow-model-downgrade[Allow Whisper model auto-downgrade on low-RAM systems]' \
                        '--back-color[ASS background box color (hex AABBGGRR)]:color' \
                        '--primary-color[Primary subtitle text color (hex AABBGGRR)]:color' \
                        '--bert-model[BERT model for collocation scoring]:model'
                    ;;
                *)
                    # Fallback for old amir video <file>
                    _arguments -s \
                        '1: : ' \
                        '2:video file:_files -g "*.mp4 *.mov *.mkv *.avi *.webm *.MP4 *.MOV *.MKV *.WEBM"' \
                        '3:resolution:_amir_resolutions' \
                        '4:quality:_amir_qualities' \
                        '*:extra files:_files'
                    ;;
            esac
            ;;

        download|dl)
            _arguments -s \
                '1: : ' \
                '2:url: ' \
                '(-s --subtitle)'{-s,--subtitle}'[Transcribe + burn subtitles via Whisper AI]' \
                '--yt-subs[Download YouTube'\''s own subtitles]' \
                '--translate[With --yt-subs: translate EN→target via LLM]' \
                '--formats[Show available resolutions before downloading]' \
                '--extreme[Auto-pick smallest resolution]' \
                '(-r --render)'{-r,--render}'[Burn subtitle into video]' \
                '--sub-only[Generate subtitle files only, skip burning]' \
                '--only-subs[Keep subtitle files; prompt to delete raw video]' \
                '(-y --yes)'{-y,--yes}'[Auto-confirm delete prompt (use with --only-subs)]' \
                '(-l --get-link)'{-l,--get-link}'[Print direct stream URL only]' \
                '(-t --target)'{-t,--target}'[Subtitle target language]:language:(fa en ar zh es fr de ru ja ko tr pt hi)' \
                '(-R --resolution)'{-R,--resolution}'[Max height in pixels]:height:(240 360 480 720 1080)' \
                '(-b --browser)'{-b,--browser}'[Browser for cookies]:browser:(chrome safari firefox brave chromium)' \
                '--cookies[Path to Netscape cookies.txt]:cookies file:_files' \
                '(-f --format)'{-f,--format}'[Image format for Instagram photos (default: jpg)]:format:(jpg png webp)'
            ;;

        audio)
            local subcmd="${words[3]}"
            # Force grouping and formatting for this context
            # This ensures headers appear directly above items instead of bunched at the top
            zstyle ":completion:${curcontext}:*" group-name ''
            zstyle ":completion:${curcontext}:*" format '-- %d --'

            if (( CURRENT == 3 )); then
                _alternative \
                    'acmds:Audio Command:((extract\:Extract\ audio\ from\ video\ file convert\:Convert\ audio\ format cut\:Trim\ or\ delete\ segments normalize\:EBU\ R128\ loudness\ normalize fade\:Fade\ in/out trim-silence\:Remove\ leading/trailing\ silence split\:Split\ audio\ into\ chunks concat\:Join\ multiple\ audio\ files to-video\:Create\ video\ from\ audio\ and\ image youtube\:Download\ audio\ from\ YouTube\ link transcribe\:Transcribe\ audio\ via\ Whisper\ \(saves\ .srt\ and\ .txt\)))' \
                    'afolders:Audio Folder:_files -/'
            else
                case "$subcmd" in
                    convert)
                        case $((CURRENT)) in
                            4) _files -g "*.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)" ;;
                            5) _values 'format' mp3 wav ogg m4a ;;
                        esac
                        ;;
                    extract)
                        case $((CURRENT)) in
                            4) _files -g "*.(mp4|mov|mkv|avi|webm|flv|MP4|MOV|MKV)" ;;
                            5) _amir_bitrates ;;
                        esac
                        ;;
                    cut)
                        case "$prev" in
                            -o|--output) _files ;;
                            -s|--start|-e|--end|-t|--to|-d|--delete|-x|--extract)
                                _message "Time (HH:MM:SS or MM:SS or seconds)"
                                ;;
                            *)
                                local _ai=0 _i
                                for (( _i=4; _i<CURRENT; _i++ )); do
                                    [[ "${words[$_i]}" =~ \.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)$ ]] && { _ai=1; break }
                                done
                                if (( _ai )) || [[ "$PREFIX" == -* ]]; then
                                    local -a cut_opts
                                    cut_opts=(
                                        '-s:Start time (keep from here)'
                                        '--start:Start time (keep from here)'
                                        '-e:End time (keep until here)'
                                        '--end:End time (keep until here)'
                                        '-d:Delete a time range (start end)'
                                        '--delete:Delete a time range (start end)'
                                        '-x:Extract named clip (start end)'
                                        '--extract:Extract named clip (start end)'
                                        '-o:Output file'
                                        '--output:Output file'
                                    )
                                    _describe -t cut_opts 'options' cut_opts
                                else
                                    _files -g "*.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)"
                                fi
                                ;;
                        esac
                        ;;
                    split)
                        case $((CURRENT)) in
                            4) _files -g "*.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)" ;;
                            5) _message "Chunk size in MB" ;;
                        esac
                        ;;
                    concat)
                        case "$prev" in
                            -o|--output) _files ;;
                            *) _files -g "*.(mp3|wav|m4a|flac|aac|MP3|WAV)" ;;
                        esac
                        ;;
                    to-video)
                        case "$prev" in
                            -i|--image) _files -g "*.(jpg|jpeg|png|webp|JPG|PNG)" ;;
                            -o|--output) _files ;;
                            *) 
                                if [[ "$PREFIX" == -* ]]; then
                                    local -a tv_opts
                                    tv_opts=(
                                        '-i:Background image'
                                        '--image:Background image'
                                        '-o:Output video file'
                                        '--output:Output video file'
                                        '--waveform:Add dynamic waveform visualization'
                                    )
                                    _describe -t tv_opts 'options' tv_opts
                                else
                                    _files -g "*.(mp3|wav|m4a|flac|aac|MP3|WAV)"
                                fi
                                ;;
                        esac
                        ;;
                    normalize)
                        case "$prev" in
                            -o|--output) _files ;;
                            --target|-l) _message "Target LUFS (e.g. -16 for YouTube, -14 for Spotify)" ;;
                            --peak|-p)   _message "Max true peak dBTP (e.g. -1)" ;;
                            *)
                                local _ai=0 _i
                                for (( _i=4; _i<CURRENT; _i++ )); do
                                    [[ "${words[$_i]}" =~ \.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)$ ]] && { _ai=1; break }
                                done
                                if (( _ai )) || [[ "$PREFIX" == -* ]]; then
                                    local -a norm_opts
                                    norm_opts=(
                                        '--target:Target integrated loudness in LUFS (default: -16)'
                                        '-l:Target integrated loudness in LUFS (default: -16)'
                                        '--peak:Max true peak in dBTP (default: -1)'
                                        '-p:Max true peak in dBTP (default: -1)'
                                        '-o:Output file'
                                        '--output:Output file'
                                    )
                                    _describe -t norm_opts 'options' norm_opts
                                else
                                    _files -g "*.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)"
                                fi ;;
                        esac
                        ;;
                    fade)
                        case "$prev" in
                            -o|--output) _files ;;
                            --in|-i|--out|-O) _message "Duration in seconds (e.g. 2)" ;;
                            *)
                                local _ai=0 _i
                                for (( _i=4; _i<CURRENT; _i++ )); do
                                    [[ "${words[$_i]}" =~ \.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)$ ]] && { _ai=1; break }
                                done
                                if (( _ai )) || [[ "$PREFIX" == -* ]]; then
                                    local -a fade_opts
                                    fade_opts=(
                                        '--in:Fade-in duration in seconds'
                                        '-i:Fade-in duration in seconds'
                                        '--out:Fade-out duration in seconds'
                                        '-O:Fade-out duration in seconds'
                                        '-o:Output file'
                                        '--output:Output file'
                                    )
                                    _describe -t fade_opts 'options' fade_opts
                                else
                                    _files -g "*.(mp3|wav|m4a|flac|aac|ogg|MP3|WAV|M4A|FLAC|AAC|OGG)"
                                fi ;;
                        esac
                        ;;
                    trim-silence)
