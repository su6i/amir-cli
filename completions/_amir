                        'stats:Overall application statistics'
                        'alert:Send urgent deadline alert email via Gmail'
                        'preview:Generate CV preview'
                    )
                    _describe -t commands 'apply subcommand' apply_cmds
                    _message "or enter a job URL"
                    ;;
                4)
                    case "${words[3]}" in
                        sync)
                            ;;
                        tui)
                            _values 'kind' 'phd' 'job'
                            ;;
                        web)
                            _message "port (default: 8765)"
                            ;;
                        stats)
                            ;;
                        alert)
                            ;;
                        phd)
                            local -a phd_cmds
                            phd_cmds=(
                                'status:Show all PhD positions with urgency table'
                                'show:Show position file and draft (no arg = list all)'
                                'list:List all position IDs and titles'
                                'sources:Show priority-ordered search sources list'
                                'search:How to find new PhD positions (with/without Claude)'
                                'add-source:Add a new search source site'
                                'draft:Generate email draft via DeepSeek'
                                'sent:Mark position as sent'
                                'reply:Record a reply received'
                                'open:Open HTML tracker in browser'
                                'init:Initialize tracking.json from files'
                            )
                            _describe -t commands 'phd subcommand' phd_cmds
                            ;;
                        job)
                            local -a job_cmds
                            job_cmds=(
                                'status:Show all job positions with urgency table'
                                'show:Show position file and draft (no arg = list all)'
                                'list:List all position IDs and titles'
                                'sources:Show priority-ordered search sources list'
                                'search:How to find new job positions (with/without Claude)'
                                'add-source:Add a new search source site'
                                'new:Create a new position file'
                                'draft:Generate email draft via DeepSeek'
                                'sent:Mark position as sent'
                                'reply:Record a reply received'
                                'open:Open HTML tracker in browser'
                                'sync:Sync Gmail job newsletters'
                                'init:Initialize tracking.json from files'
                            )
                            _describe -t commands 'job subcommand' job_cmds
                            ;;
                        preview)
                            _apply_arguments
                            ;;
                    esac
                    ;;
                5)
                    case "${words[3]}" in
                        phd|job)
                            case "${words[4]}" in
                                status)
                                    local -a track_opts
                                    track_opts=('--track:Filter by track')
                                    _describe -t opts 'options' track_opts
                                    ;;
                                draft)
                                    local -a draft_opts
                                    draft_opts=(
                                        '--force:Regenerate existing draft'
                                        '--lang:Language (fr/en)'
                                    )
                                    _describe -t opts 'options' draft_opts
                                    ;;
                                sent)
                                    local -a sent_opts
                                    sent_opts=('--date:Date sent (YYYY-MM-DD)')
                                    _describe -t opts 'options' sent_opts
                                    ;;
                                reply)
                                    local -a reply_opts
                                    reply_opts=('--type:Reply type (positive/negative/bounce/info)')
                                    _describe -t opts 'options' reply_opts
                                    ;;
                                open)
                                    if [[ "${words[3]}" == "phd" ]]; then
                                        _values 'track' 'general' 'finance' 'all'
                                    else
                                        _values 'track' 'devops' 'ai_engineer' 'polyvalent' 'all'
                                    fi
                                    ;;
                                sync)
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
            esac
            ;;
        llm-lists)
            case $((CURRENT)) in
                3)
                    local -a providers
                    providers=(
                        'gemini:Google Gemini models'
                        'openai:OpenAI GPT models'
                        'deepseek:DeepSeek models'
                        'groq:Groq models'
                        'anthropic:Claude models'
                    )
                    _describe -t providers 'LLM provider' providers
                    ;;
                4)
                    local -a export_opts
                    export_opts=(
                        '-e:Export format'
                        '--export:Export format'
                    )
                    _describe -t export_opts 'options' export_opts
                    ;;
                5)
                    if [[ "${words[4]}" == "-e" || "${words[4]}" == "--export" ]]; then
                        local -a formats
                        formats=(
                            'pdf:Export as PDF'
                            'md:Export as Markdown'
                            'jpg:Export as image'
                        )
                        _describe -t formats 'export format' formats
                    fi
                    ;;
            esac
            ;;
        clean)
            _message "Cleaning system temporary files..."
            ;;
    esac
}

