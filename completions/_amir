_amir_cv_roles() {
    # Dynamically detect roles from canonical *-CV_ROLE_source.json files in CV repo
    local cv_repo="${HOME}/@-github/CV"
    local -a roles=()

    if [[ -d "$cv_repo/data" ]]; then
        # Canonical format: {SLUG}-CV_{Role}_source.json  →  extract Role
        for file in "$cv_repo/data"/*-CV_*_source.json; do
            if [[ -f "$file" ]]; then
                local base="${file##*-CV_}"   # strip up to last -CV_
                local role="${base%_source.json}"
                [[ -n "$role" ]] && roles+=("${role:l}")  # lowercase
            fi
        done
        # Legacy format: resume_profile_ROLE.json
        for file in "$cv_repo/data"/resume_profile_*.json; do
            if [[ -f "$file" ]]; then
                local role="${file##*/resume_profile_}"
                role="${role%.json}"
                [[ -n "$role" ]] && roles+=("$role")
            fi
        done
    fi

    # Fallback to hardcoded defaults if no files found
    if (( ${#roles[@]} == 0 )); then
        roles=('ai' 'it' 'phd' 'python' 'devops')
    fi

    roles=($(printf '%s\n' "${roles[@]}" | sort -u))
    _values 'role' "${roles[@]}"
}

