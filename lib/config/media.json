{
  "encoding": {
    "bitrate": {
      "multiplier": 1.1,
      "fallback": "2.5M",
      "min": "500K",
      "max": "50M"
    },
    "quality": {
      "default_crf": 23,
      "default_quality": 70,
      "default_preset": "medium"
    },
    "hardware_acceleration": {
      "priority": [
        {"encoder": "hevc_videotoolbox", "platform": "apple_silicon", "codec": "h265"},
        {"encoder": "hevc_nvenc", "platform": "nvidia", "codec": "h265"},
        {"encoder": "hevc_qsv", "platform": "intel", "codec": "h265"},
        {"encoder": "hevc_amf", "platform": "amd", "codec": "h265"},
        {"encoder": "h264_videotoolbox", "platform": "apple_silicon", "codec": "h264"},
        {"encoder": "h264_nvenc", "platform": "nvidia", "codec": "h264"},
        {"encoder": "h264_qsv", "platform": "intel", "codec": "h264"},
        {"encoder": "h264_amf", "platform": "amd", "codec": "h264"}
      ],
      "fallback": {
        "encoder": "libx264",
        "codec": "h264"
      }
    }
  },
  "audio": {
    "codec": "aac",
    "sample_rate": 44100,
    "channels": "stereo"
  },
  "video": {
    "subtitle": {
      "merge_sec": 2.0,
      "min_words": 5,
      "max_words": 15,
      "break_chars": [".", "?", "!", "...", "。", "？", "！", ",", ";", ":", "،", "؛"],
      "split_words": [
        "and", "but", "because", "so", "if", "when", "while", "although", "what", "why", "where", "how", "who"
      ],
      "styles": {
        "Lecture": {
          "font_size": 16,
          "primary_color": "&H00FFFF00"
        },
        "Vlog": {
          "font_size": 14,
          "primary_color": "&H00FFFFFF"
        }
      },
      "fonts": {
        "english": {
          "name": "Arial",
          "scale": 1.0
        },
        "persian": {
          "name": "Vazirmatn",
          "scale": 1.0
        }
      }
    }
  },
  "metadata": {
    "version": "1.1.0",
    "last_updated": "2026-02-16",
    "description": "Centralized media encoding standards for Amir CLI with automatic hardware detection"
  }
}
